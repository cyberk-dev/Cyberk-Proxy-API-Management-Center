# Example config.yaml demonstrating rate-limit plugin features.
# This file is a SUPERSET of CLIProxyAPI's config.yaml — the base proxy fields
# (api-keys, generative-language-api-key, etc.) are unchanged. The plugin reads
# a separate top-level `ratelimit:` section that the upstream proxy ignores.

# ── Base CLIProxyAPI config (standard fields) ────────────────────────────────
port: 8317
auth-dir: "./auths"

# Inline API keys accepted by the proxy's built-in access provider.
api-keys:
  - alice-key
  - bob-key
  - vip-key

# ── Rate-limit plugin config (additive, optional) ────────────────────────────
# Resolution order when a request comes in:
#   1. models[model].keys[apiKey]             — exact model + per-key override
#   2. models[wildcard].keys[apiKey]           — wildcard + per-key override
#   3. models[model]                           — exact model default
#   4. models[wildcard]                        — wildcard default (most-specific wins)
#   5. top-level requests/window               — global default
#
# If nothing matches, request is not rate-limited.
ratelimit:
  # Default window + limit applied to any (apiKey, model) not matched above.
  window: 5h
  requests: 500

  models:
    # Exact model match — beats any wildcard below.
    gpt-5.4:
      window: 2h
      requests: 100
      keys:
        # Per-key override for this model. 0 = skip (fall through to model default).
        alice-key: 50

    # Wildcard pattern using path.Match syntax (`*`, `?`, `[abc]`).
    # Specificity (literal char count) breaks ties: "gpt-5.4-*" beats "gpt-*".
    "gpt-5.4-*":
      requests: 300
      # Inherits window from top-level (5h) since not specified.

    "claude-*-sonnet-*":
      window: 10m
      requests: 60

    # No window → inherits 5h. No keys → applies uniformly.
    gemini-2.5-pro:
      requests: 200

# ── Policy: block specific request shapes (optional) ─────────────────────────
# Reject requests whose JSON body carries a forbidden field value, regardless
# of API key or model. Runs BEFORE rate-limit accounting, so a blocked request
# never consumes per-key quota.
#
# Currently supported:
#   block_service_tiers — list of OpenAI `service_tier` values to reject.
#     OpenAI's "priority" tier costs ~2× the quota of "default", so operators
#     often want to disable it across the board. Match is case-insensitive;
#     missing field always passes through (Anthropic / Gemini routes do not
#     send service_tier and are unaffected).
#
# Omit the block (or leave the list empty) to disable the feature entirely.
# Rejection format mirrors the rate-limit error so clients see a consistent
# 400 invalid_request_error shape.
policy:
  block_service_tiers:
    - priority

# ── Prompt logging (optional) ────────────────────────────────────────────────
# Capture the final user message of every chat request to a daily-rotated
# JSONL file for offline analysis. Earlier turns of a conversation are NOT
# duplicated per request — the previous request's log already contains them,
# so logging only the last user message keeps the file small while preserving
# full user intent across the session.
#
# Content normalization:
#   - text blocks      → kept verbatim, middle-truncated when > max_text_bytes
#   - image / document → base64 stripped, replaced with {media_type, bytes, sha256}
#   - tool_use/result  → dropped (not user-authored content)
#
# Supported routes: /v1/messages (Anthropic), /v1/chat/completions,
# /v1/responses, /v1beta/models/*:(stream)generateContent. Other paths are
# ignored. Both successful and rejected requests are logged — promptlog runs
# before policy/ratelimit so blocked attempts still appear in the log.
#
# Output: <dir>/prompts-YYYY-MM-DD.jsonl (UTC date). One JSON object per line.
# Writes are async + non-blocking; queue overflow drops the entry (counted in
# logs on shutdown) rather than back-pressuring the request path.
#
# Omit this block entirely to disable. Setting `enabled: false` also disables.
prompt_log:
  enabled: true
  # Relative paths resolve to <config-dir>/<dir>. Absolute paths are used as-is.
  dir: prompts
  # Per-block cap; longer text is middle-truncated keeping the first/last
  # halves so the user's intent at start and end of long pastes survives.
  max_text_bytes: 51200
  # Bounded queue for the async writer. If sustained traffic exceeds disk
  # write speed, increase this; if it grows much beyond ~10k, the bottleneck
  # is the writer goroutine and you'll want a different storage backend.
  queue_size: 1024

  # Dynamic prompt-template detection. The writer maintains an in-memory
  # rune-trie over the last `window` prompts; when a prefix of length ≥
  # `min_len` runes is shared by ≥ `min_occur` distinct prompts, it is
  # registered as a template. Future entries with that prefix get encoded
  # as `prompt_template: <hash>` + the suffix only — drastically shrinking
  # the JSONL log when the same skill body, slash command, or compaction
  # summary recurs.
  #
  # Templates persist to <dir>/templates.jsonl. Two read endpoints expose
  # them: GET /v0/management/prompts/templates (catalog) and
  # GET /v0/management/prompts/templates/:hash (full text). The detail
  # endpoint accepts ?inline_templates=1 to splice bodies back into prompts
  # server-side for clients that want self-contained responses.
  #
  # Omit `templates:` entirely to inherit defaults; set `enabled: false` to
  # disable detection (existing templates still apply via Match — clear
  # templates.jsonl to fully revert).
  templates:
    enabled: true
    min_len: 200          # chars; below this the prefix is too generic
    min_occur: 3          # distinct prompts that must share the prefix
    window: 5000          # rolling observation window
    scan_every_seconds: 300

# ── Weighted routing for Codex (optional) ────────────────────────────────────
# Distribute Codex requests across upstream accounts proportionally to their
# subscription weight, derived from the `plan_type` claim embedded in each
# Codex auth's JWT (read from auth.Attributes["plan_type"]).
#
# Omit this block entirely to keep SDK default routing (round-robin / fill-first).
# Presence of an empty block `codex_weights: {}` enables the feature with the
# built-in defaults below.
#
# Weights are relative — `pro: 10, plus: 1` yields ~10× more traffic to Pro.
# Plans not listed here inherit the defaults shown below; truly unknown plans
# (e.g. a future tier not yet in this file) fall back to weight 1, so traffic
# is never silently dropped.
#
# Smooth Weighted Round Robin distributes traffic deterministically — the
# `pro:10,plus:1` example above picks pro 10 times and plus 1 time in every
# 11-request cycle, in a smooth interleaved order.
#
# Claude / Gemini / other providers: unaffected. Only Codex is weighted here.
# Session affinity (if enabled above) still wins over weighted pick — a sticky
# session always returns to its bound auth regardless of weight.
codex_weights:
  pro: 10
  prolite: 5
  plus: 1
  free: 1
  team: 1
  business: 1
  go: 1
